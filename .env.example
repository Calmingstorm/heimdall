# Discord bot token (required)
DISCORD_TOKEN=your-discord-bot-token

# Webhook secret for Gitea/Grafana webhook receiver (optional)
# WEBHOOK_SECRET=your-webhook-secret

# Comma-separated webhook IDs allowed to bypass bot-author check (optional)
# ALLOWED_WEBHOOK_IDS=123456789,987654321

# Ollama URL for embeddings (optional, defaults to http://localhost:11434)
# Docker users: docker-compose.yml auto-sets this to http://host.docker.internal:11434
# Incus/bare metal: default http://localhost:11434 works if Ollama runs locally
# OLLAMA_URL=http://localhost:11434

# Browser service token (optional, defaults to "loki-internal")
# Set a unique token if exposing the browser service outside Docker network
# BROWSER_TOKEN=your-browser-token

# Timezone (optional, defaults to UTC)
# TZ=America/New_York
