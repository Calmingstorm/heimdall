# Discord bot token (required)
DISCORD_TOKEN=your-discord-bot-token

# Anthropic API key — used for Haiku classification only (~$0.0002/call)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Webhook secret for Gitea/Grafana webhook receiver (optional)
WEBHOOK_SECRET=your-webhook-secret

# Comma-separated webhook IDs allowed to bypass bot-author check (optional)
# ALLOWED_WEBHOOK_IDS=123456789,987654321

# Timezone (optional, defaults to UTC)
# TZ=America/New_York
