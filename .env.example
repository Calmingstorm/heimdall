# =============================================================================
# Heimdall Environment Configuration
# Copy this file to .env and fill in your values.
# Only DISCORD_TOKEN is required — everything else is optional.
# =============================================================================

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Your Discord bot token. Create a bot at https://discord.com/developers/applications
# Bot requires: MESSAGE CONTENT intent, SERVER MEMBERS intent
DISCORD_TOKEN=your-discord-bot-token-here

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Webhook signature verification secret (for Gitea/Grafana webhook receiver)
# Only needed if you enable webhooks in config.yml
# WEBHOOK_SECRET=your-webhook-secret

# Comma-separated Discord webhook IDs that bypass the bot-author check.
# Useful for allowing webhook-based integrations to interact with Heimdall.
# ALLOWED_WEBHOOK_IDS=

# Token used in the browser automation CDP URL (Playwright/Browserless).
# Only needed if you enable browser automation in config.yml.
# Defaults to "heimdall-internal" if not set.
# BROWSER_TOKEN=your-browser-token

# Timezone (IANA format). Defaults to UTC.
# TZ=America/New_York

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Codex (ChatGPT) authentication is NOT configured here — it uses OAuth tokens
# stored in data/codex_auth.json. Run the setup command to authenticate:
#
#   python -m src.setup              # Browser-based login
#   python -m src.setup --headless   # Headless server (paste callback URL)
#   python -m src.setup --list       # View configured accounts
#
# See README.md for full setup instructions.
